# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
test-results/
playwright-report/
playwright/.cache/

# capacitor native platforms
/ios/
/android/

# build artifacts
/builds/

# sensitive slides
public/credentials-slide.*
public/training/audio/.content-hashes.json
# Use bun.lock instead
package-lock.json

# Local dev helper scripts (auto-signin, QA runner)
.klo-*.mjs
.env.local.backup*
